# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_KEY=your_supabase_anon_key

# Service role key — needed only for running `npm run db:seed` locally
# AND for the Netlify stripe-webhook function. NEVER expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe — add these to Netlify environment variables too
# VITE_STRIPE_PUBLISHABLE_KEY is safe for the browser; the others are server-only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLUS_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Anthropic — server-only, used by ask-pippa function
ANTHROPIC_API_KEY=sk-ant-...

# Resend — server-only, used by email functions
RESEND_API_KEY=re_...

# Sentry — browser error monitoring (optional, leave blank to disable)
VITE_SENTRY_DSN=https://...@sentry.io/...
